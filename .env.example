# --- Monitor: cyclically detects work to be done and adds tasks to the list ---

# Monitor model (alias or full name)
CLAUDE_WORKER_MONITOR_MODEL=sonnet

# Monitor effort (reasoning effort level): low, medium, high, xhigh, max
CLAUDE_WORKER_MONITOR_EFFORT=medium

# Interval between monitor cycles (ms). 900000 = 15 min
CLAUDE_WORKER_MONITOR_INTERVAL_MS=900000

# Monitor working hours (local time). Empty/unset = 24/7.
# Format HH:MM-HH:MM; end is exclusive; a window across midnight is allowed (e.g. 22:00-06:00).
# CLAUDE_WORKER_MONITOR_ACTIVE_HOURS=08:00-18:00
# Monitor working days. Empty/unset = all days. Tokens: mon,tue,wed,thu,fri,sat,sun;
# ranges (mon-fri) and lists (mon-fri,sun).
# CLAUDE_WORKER_MONITOR_ACTIVE_DAYS=mon-fri

# Optional
# CLAUDE_WORKER_MONITOR_PROMPT_FILE=./prompts/monitor.prompt.md
# CLAUDE_WORKER_MONITOR_SYSTEM_PROMPT_FILE=./prompts/monitor.system.md
# CLAUDE_WORKER_MONITOR_SESSION_TIMEOUT_MS=300000 # hard limit for a monitor session

# --- Executor: completes tasks from the list, one task = one session ---

# Executor model — powerful by design
CLAUDE_WORKER_EXECUTOR_MODEL=opus

# Executor effort (reasoning effort level): low, medium, high, xhigh, max
CLAUDE_WORKER_EXECUTOR_EFFORT=high

# Optional
# CLAUDE_WORKER_EXECUTOR_PROMPT_FILE=./prompts/executor.prompt.md
# CLAUDE_WORKER_EXECUTOR_SYSTEM_PROMPT_FILE=./prompts/executor.system.md
# CLAUDE_WORKER_EXECUTOR_SESSION_TIMEOUT_MS=3600000

# --- Summarizer: after each executor task, writes a session summary to memory ---

# Summarizer model
# CLAUDE_WORKER_SUMMARIZER_MODEL=sonnet

# Summarizer effort: low, medium, high, xhigh, max
# CLAUDE_WORKER_SUMMARIZER_EFFORT=medium

# Optional
# CLAUDE_WORKER_SUMMARIZER_SYSTEM_PROMPT_FILE=./prompts/summarizer.system.md
# CLAUDE_WORKER_SUMMARIZER_SESSION_TIMEOUT_MS=300000 # hard limit for a summarizer session (default 5 min)

# --- Shared ---

# CLAUDE_WORKER_TASKS_FILE=./data/tasks.json     # persistent task store (dedup + history)
# CLAUDE_WORKER_MEMORY_DB=./data/memory.db       # long-term memory (SQLite + FTS5)
# CLAUDE_WORKER_STREAM_PARTIAL=true              # token-by-token text streaming (default true)
# CLAUDE_WORKER_CWD=./workspace                  # session working directory (isolated from agent code)

# Separate Claude Code config directory (e.g. a different profile: own MCP/subscription).
# Passed straight to the claude process. A leading ~ in the path is supported.
# CLAUDE_CONFIG_DIR=
