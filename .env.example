# --- Monitor: cyklicznie wykrywa pracę do zrobienia i dodaje zadania na listę ---

# Model monitora (alias lub pełna nazwa) — z założenia tani
CLAUDE_WORKER_MONITOR_MODEL=haiku

# Effort monitora (poziom wysiłku rozumowania): low, medium, high, xhigh, max
CLAUDE_WORKER_MONITOR_EFFORT=medium

# Interwał między cyklami monitora (ms). 900000 = 15 min
CLAUDE_WORKER_MONITOR_INTERVAL_MS=900000

# Godziny pracy monitora (czas lokalny). Puste/brak = cała doba.
# Format HH:MM-HH:MM; koniec ekskluzywny; okno przez północ dozwolone (np. 22:00-06:00).
# CLAUDE_WORKER_MONITOR_ACTIVE_HOURS=08:00-18:00
# Dni pracy monitora. Puste/brak = wszystkie dni. Tokeny: mon,tue,wed,thu,fri,sat,sun;
# zakresy (mon-fri) i listy (mon-fri,sun).
# CLAUDE_WORKER_MONITOR_ACTIVE_DAYS=mon-fri

# Opcjonalne
# CLAUDE_WORKER_MONITOR_PROMPT_FILE=./prompts/monitor.prompt.md
# CLAUDE_WORKER_MONITOR_SYSTEM_PROMPT_FILE=./prompts/monitor.system.md
# CLAUDE_WORKER_MONITOR_SESSION_TIMEOUT_MS=300000 # twardy limit sesji monitora

# --- Egzekutor: wykonuje zadania z listy, jedno zadanie = jedna sesja ---

# Model egzekutora — z założenia mocny
CLAUDE_WORKER_EXECUTOR_MODEL=opus

# Effort egzekutora (poziom wysiłku rozumowania): low, medium, high, xhigh, max
CLAUDE_WORKER_EXECUTOR_EFFORT=high

# Opcjonalne
# CLAUDE_WORKER_EXECUTOR_PROMPT_FILE=./prompts/executor.prompt.md
# CLAUDE_WORKER_EXECUTOR_SYSTEM_PROMPT_FILE=./prompts/executor.system.md
# CLAUDE_WORKER_EXECUTOR_SESSION_TIMEOUT_MS=3600000

# --- Podsumowujący: po każdym zadaniu egzekutora zapisuje podsumowanie sesji do pamięci ---

# Model podsumowującego — z założenia tani
# CLAUDE_WORKER_SUMMARIZER_MODEL=haiku

# Effort podsumowującego: low, medium, high, xhigh, max
# CLAUDE_WORKER_SUMMARIZER_EFFORT=low

# Opcjonalne
# CLAUDE_WORKER_SUMMARIZER_SYSTEM_PROMPT_FILE=./prompts/summarizer.system.md
# CLAUDE_WORKER_SUMMARIZER_SESSION_TIMEOUT_MS=300000 # twardy limit sesji podsumowującej (domyślnie 5 min)

# --- Wspólne ---

# CLAUDE_WORKER_TASKS_FILE=./data/tasks.json     # trwały magazyn zadań (dedup + historia)
# CLAUDE_WORKER_MEMORY_DB=./data/memory.db       # pamięć długoterminowa (SQLite + FTS5)
# CLAUDE_WORKER_STREAM_PARTIAL=true              # streaming tekstu token-po-tokenie (domyślnie true)
# CLAUDE_WORKER_CWD=./workspace                  # katalog roboczy sesji (izolacja od kodu agenta)

# Osobny katalog konfiguracji Claude Code (np. inny profil: własne MCP/subskrypcja).
# Przekazywany wprost do procesu claude. Obsługiwane jest ~ w ścieżce.
# CLAUDE_CONFIG_DIR=
