# Model sesji (alias lub pełna nazwa)
CLAUDE_WORKER_MODEL=haiku

# Interwał między startami sesji (ms). 300000 = 5 min
CLAUDE_WORKER_INTERVAL_MS=300000

# Opcjonalne
# CLAUDE_WORKER_PERMISSION_MODE=default        # default | acceptEdits | bypassPermissions | plan
# CLAUDE_WORKER_SESSION_TIMEOUT_MS=600000      # twardy limit sesji
# CLAUDE_WORKER_STREAM_PARTIAL=true            # streaming tekstu token-po-tokenie (domyślnie true)
# CLAUDE_WORKER_CWD=./workspace                 # katalog roboczy sesji (izolacja od kodu agenta)

# Osobny katalog konfiguracji Claude Code (np. inny profil: własne MCP/subskrypcja).
# Przekazywany wprost do procesu claude. Obsługiwane jest ~ w ścieżce.
# CLAUDE_CONFIG_DIR=
